<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp"
    tools:context=".pertemuan_2.BangunDatarActivity">

    <!-- Judul -->
    <TextView
        android:id="@+id/tv_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Kalkulator Bangun Datar &amp; Ruang"
        android:textSize="20sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Section Segitiga -->
    <TextView
        android:id="@+id/tv_label_segitiga"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="Luas Segitiga"
        android:textSize="18sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_title" />

    <EditText
        android:id="@+id/et_alas"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:hint="Masukkan Alas"
        android:inputType="numberDecimal"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_label_segitiga" />

    <EditText
        android:id="@+id/et_tinggi"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:hint="Masukkan Tinggi"
        android:inputType="numberDecimal"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/et_alas" />

    <Button
        android:id="@+id/btn_hitung_segitiga"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Hitung Luas Segitiga"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/et_tinggi" />

    <TextView
        android:id="@+id/tv_hasil_segitiga"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:text="Hasil: "
        android:textSize="16sp"
        app:layout_constraintBottom_toBottomOf="@id/btn_hitung_segitiga"
        app:layout_constraintStart_toEndOf="@id/btn_hitung_segitiga"
        app:layout_constraintTop_toTopOf="@id/btn_hitung_segitiga" />

    <!-- Divider -->
    <View
        android:id="@+id/divider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="24dp"
        android:background="@android:color/darker_gray"
        app:layout_constraintTop_toBottomOf="@id/btn_hitung_segitiga" />

    <!-- Section Kubus -->
    <TextView
        android:id="@+id/tv_label_kubus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="Volume Kubus"
        android:textSize="18sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/divider" />

    <EditText
        android:id="@+id/et_sisi"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:hint="Masukkan Sisi"
        android:inputType="numberDecimal"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_label_kubus" />

    <Button
        android:id="@+id/btn_hitung_kubus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Hitung Volume Kubus"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/et_sisi" />

    <TextView
        android:id="@+id/tv_hasil_kubus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:text="Hasil: "
        android:textSize="16sp"
        app:layout_constraintBottom_toBottomOf="@id/btn_hitung_kubus"
        app:layout_constraintStart_toEndOf="@id/btn_hitung_kubus"
        app:layout_constraintTop_toTopOf="@id/btn_hitung_kubus" />

</androidx.constraintlayout.widget.ConstraintLayout>
